#!/bin/bash
# verify-ns-type <namespace> <dev|prod> — namespace exists with the DCS type label.
ns="${1:?namespace required}"
want="${2:?type required}"
got=$(oc get namespace "$ns" -o jsonpath='{.metadata.labels.dcs\.airbus/namespace-type}' 2>/dev/null)
if [ -z "$got" ]; then
  echo "Namespace '$ns' not found or missing the dcs.airbus/namespace-type label. Apply the namespace manifest first." >&2
  exit 1
fi
if [ "$got" != "$want" ]; then
  echo "Namespace '$ns' has type '$got', expected '$want'." >&2
  exit 1
fi
echo "OK: namespace '$ns' is type '$want'."
