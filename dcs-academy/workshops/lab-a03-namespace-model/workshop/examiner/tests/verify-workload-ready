#!/bin/bash
# verify-workload-ready <deployment> <namespace> — deployment has >=1 available replica.
name="${1:?deployment required}"
ns="${2:?namespace required}"
avail=$(oc get deployment "$name" -n "$ns" -o jsonpath='{.status.availableReplicas}' 2>/dev/null)
if [ -z "$avail" ] || [ "$avail" -lt 1 ] 2>/dev/null; then
  echo "Deployment '$name' in namespace '$ns' has no available replicas yet (got '${avail:-none}'). Give it a moment or check 'oc describe deployment $name -n $ns'." >&2
  exit 1
fi
echo "OK: deployment '$name' in '$ns' has $avail available replica(s)."
