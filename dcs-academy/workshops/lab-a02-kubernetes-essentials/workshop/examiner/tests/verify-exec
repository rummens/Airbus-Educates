#!/bin/bash
# verify-exec <deployment>
# Passes when a command can be executed inside the deployment's container.
name="${1:?deployment name required}"
out=$(oc exec "deployment/$name" -- echo exec-ok 2>/dev/null)
if [ "$out" != "exec-ok" ]; then
  echo "Could not exec into deployment/$name. Is a pod running? Try 'oc get pods'." >&2
  exit 1
fi
echo "OK: exec into deployment/$name works."
