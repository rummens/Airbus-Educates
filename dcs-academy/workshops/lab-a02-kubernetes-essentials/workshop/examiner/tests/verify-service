#!/bin/bash
# verify-service <service>
# Passes when the Service exists and has at least one ready endpoint.
name="${1:?service name required}"
if ! oc get service "$name" >/dev/null 2>&1; then
  echo "Service '$name' not found. Apply service.yaml first." >&2
  exit 1
fi
eps=$(oc get endpoints "$name" -o jsonpath='{.subsets[*].addresses[*].ip}' 2>/dev/null)
if [ -z "$eps" ]; then
  echo "Service '$name' exists but has no ready endpoints — is the Deployment running and do the selector labels match?" >&2
  exit 1
fi
echo "OK: service '$name' has endpoints: $eps"
