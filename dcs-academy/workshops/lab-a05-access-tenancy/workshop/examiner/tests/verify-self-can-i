#!/bin/bash
# verify-self-can-i <verb> <resource> <yes|no> — your own effective permission in this namespace.
verb="${1:?verb required}"
res="${2:?resource required}"
want="${3:?expected yes|no required}"
got=$(oc auth can-i "$verb" "$res" 2>/dev/null)
if [ "$got" != "$want" ]; then
  echo "can-i $verb $res returned '${got:-<empty>}', expected '$want'." >&2
  exit 1
fi
echo "OK: can-i $verb $res = '$want' (as expected)."
