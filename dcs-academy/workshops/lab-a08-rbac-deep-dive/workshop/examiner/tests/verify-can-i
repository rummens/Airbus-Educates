#!/bin/bash
# verify-can-i <verb> <resource> <serviceaccount> <yes|no>
# Checks the effective permission of a ServiceAccount via impersonation.
verb="${1:?verb required}"
res="${2:?resource required}"
sa="${3:?serviceaccount required}"
want="${4:?expected yes|no required}"
got=$(oc auth can-i "$verb" "$res" --as="system:serviceaccount:${SESSION_NAMESPACE}:${sa}" 2>/dev/null)
if [ "$got" != "$want" ]; then
  echo "can-i $verb $res as '$sa' returned '${got:-<empty>}', expected '$want'. Check the Role rules and the RoleBinding subject." >&2
  exit 1
fi
echo "OK: can-i $verb $res as '$sa' = '$want' (as expected)."
