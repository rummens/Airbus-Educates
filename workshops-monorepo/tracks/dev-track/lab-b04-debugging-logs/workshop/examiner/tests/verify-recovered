#!/bin/bash
# verify-recovered <app-label> <service> <port>
# Passes when a pod with app=<label> is Ready AND the Service answers HTTP 200 —
# i.e. the fix worked and the app is serving again.
app="${1:?app label required}"
svc="${2:-hello-dcs}"
port="${3:-8080}"
ready=$(oc get pods -l "app=$app" \
  -o jsonpath='{range .items[*]}{.status.conditions[?(@.type=="Ready")].status}{"\n"}{end}' \
  2>/dev/null | grep -c '^True')
if [ "${ready:-0}" -lt 1 ]; then
  echo "No Ready pod with app=$app yet. Run 'oc get pods' — is it still pulling or crashing? Did 'oc rollout status' finish?" >&2
  exit 1
fi
url="http://${svc}.${SESSION_NAMESPACE}.svc:${port}"
code=$(curl -s -o /dev/null -m 5 -w '%{http_code}' "$url" 2>/dev/null)
if [ "$code" != "200" ]; then
  echo "GET $url returned '${code:-no response}', expected 200. The pod is Ready but the Service isn't serving yet — give it a moment and re-run." >&2
  exit 1
fi
echo "OK: pod with app=$app is Ready and $url returned 200 — recovered."
