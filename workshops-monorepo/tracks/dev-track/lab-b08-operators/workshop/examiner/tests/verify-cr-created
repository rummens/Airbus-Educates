#!/bin/bash
# Verify the sample-db Cluster CR was created (does not require reconciliation yet).
if ! oc get cluster.postgresql.cnpg.io sample-db >/dev/null 2>&1; then
  echo "Custom resource 'sample-db' (cluster.postgresql.cnpg.io) not found in $(oc project -q 2>/dev/null). Did you apply sample-cr.yaml with envsubst?" >&2
  exit 1
fi
echo "OK: sample-db Cluster CR exists."
