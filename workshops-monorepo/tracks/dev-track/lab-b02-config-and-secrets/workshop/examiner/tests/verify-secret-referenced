#!/bin/bash
# verify-secret-referenced — the Secret exists AND the Deployment injects it (secretKeyRef).
name="${1:-hello-dcs-secret}"
if ! oc get secret "$name" >/dev/null 2>&1; then
  echo "Secret '$name' not found. Apply secret.yaml first." >&2
  exit 1
fi
refs=$(oc get deployment hello-dcs -o jsonpath='{.spec.template.spec.containers[0].env[*].valueFrom.secretKeyRef.name}' 2>/dev/null)
if ! echo "$refs" | grep -qw "$name"; then
  echo "The hello-dcs Deployment does not reference Secret '$name' via secretKeyRef. Apply deployment-configured.yaml." >&2
  exit 1
fi
echo "OK: Secret '$name' exists and is injected by the Deployment."
