#!/bin/bash
# verify-marker <deployment> <path> <expected-substring>
# Passes when the file at <path> inside the deployment's pod contains <expected-substring>.
# Used twice: after writing the marker (present), and after a pod restart (survived).
name="${1:?deployment name required}"
path="${2:?file path required}"
expected="${3:?expected content required}"
content=$(oc exec "deployment/$name" -- cat "$path" 2>/dev/null)
if [ -z "$content" ]; then
  echo "Could not read '$path' in deployment/$name (empty or missing). Is a pod running, and was the marker written to the mounted volume? Try 'oc exec deployment/$name -- ls -l $(dirname "$path")'." >&2
  exit 1
fi
if ! printf '%s' "$content" | grep -q -- "$expected"; then
  echo "File '$path' does not contain '$expected' (found: '$content'). If this is after a pod restart, the data did not persist — check the volume is backed by the PVC." >&2
  exit 1
fi
echo "OK: '$path' contains '$expected'."
