#!/bin/bash
# verify-probes <deployment> — the deployment's container defines BOTH a readiness and a
# liveness probe.
name="${1:?deployment name required}"
ready=$(oc get deployment "$name" -o jsonpath='{.spec.template.spec.containers[0].readinessProbe}' 2>/dev/null)
live=$(oc get deployment "$name" -o jsonpath='{.spec.template.spec.containers[0].livenessProbe}' 2>/dev/null)
if [ -z "$ready" ]; then
  echo "Deployment '$name' has no readinessProbe. Add one (httpGet / on 8080) and re-apply." >&2
  exit 1
fi
if [ -z "$live" ]; then
  echo "Deployment '$name' has no livenessProbe. Add one (httpGet / on 8080) and re-apply." >&2
  exit 1
fi
echo "OK: deployment '$name' has both readiness and liveness probes."
