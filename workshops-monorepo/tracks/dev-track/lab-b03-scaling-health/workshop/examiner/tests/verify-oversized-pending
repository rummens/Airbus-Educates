#!/bin/bash
# verify-oversized-pending — at least one hello-dcs Pod is Pending, i.e. the oversized
# request was rejected by the namespace quota (the constraint bites, as intended).
pending=$(oc get pods -l app=hello-dcs \
  -o jsonpath='{range .items[*]}{.status.phase}{"\n"}{end}' 2>/dev/null | grep -c '^Pending')
if [ "${pending:-0}" -lt 1 ]; then
  echo "No Pending hello-dcs Pod yet. Apply deployment-oversized.yaml and check 'oc get pods' + 'oc get events' — the quota should hold a replica in Pending." >&2
  exit 1
fi
echo "OK: an oversized replica is Pending — the namespace quota rejected it."
