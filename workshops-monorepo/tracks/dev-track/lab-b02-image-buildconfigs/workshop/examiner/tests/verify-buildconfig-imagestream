#!/bin/bash
# Verify the BuildConfig and its output ImageStream both exist.
if ! oc get buildconfig hello-dcs-s2i >/dev/null 2>&1; then
  echo "BuildConfig 'hello-dcs-s2i' not found in $(oc project -q). Did you apply buildconfig-s2i.yaml with envsubst?" >&2
  exit 1
fi
if ! oc get imagestream hello-dcs-built >/dev/null 2>&1; then
  echo "ImageStream 'hello-dcs-built' not found in $(oc project -q). Did you apply imagestream.yaml?" >&2
  exit 1
fi
echo "OK: BuildConfig 'hello-dcs-s2i' and ImageStream 'hello-dcs-built' both exist."
exit 0
