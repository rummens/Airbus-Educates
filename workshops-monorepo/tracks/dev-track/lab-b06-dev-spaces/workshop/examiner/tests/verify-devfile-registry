#!/bin/bash
# verify-devfile-registry — the devfile references the DCS Harbor registry variable and no
# external registry (air-gapped house standard). Always assertable, live or concept mode.
f="${1:-$HOME/exercises/devfile.yaml}"
if [ ! -f "$f" ]; then
  echo "devfile not found at $f." >&2
  exit 1
fi
if ! grep -q 'DCS_REGISTRY' "$f"; then
  echo "The devfile does not reference \${DCS_REGISTRY}. On DCS every workspace image must come from Harbor via the registry variable." >&2
  exit 1
fi
if grep -Eq 'image:\s*(docker\.io|quay\.io|registry\.redhat\.io|ghcr\.io)' "$f"; then
  echo "The devfile references an external registry. Air-gapped: mirror the image into Harbor and use \${DCS_REGISTRY}." >&2
  exit 1
fi
echo "OK: the devfile pulls its workspace image from the DCS Harbor registry (no external registries)."
