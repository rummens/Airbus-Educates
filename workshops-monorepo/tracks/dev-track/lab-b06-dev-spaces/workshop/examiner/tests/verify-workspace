#!/bin/bash
# verify-workspace — (LIVE mode only) a Dev Spaces workspace Pod is Running for this user.
# In concept mode (no Dev Spaces instance) this can't pass; the workshop uses a knowledge
# check there instead, so only invoke this test on the live path.
running=$(oc get pods -l controller.devfile.io/devworkspace_name \
  -o jsonpath='{range .items[*]}{.status.phase}{"\n"}{end}' 2>/dev/null | grep -c '^Running')
if [ "${running:-0}" -lt 1 ]; then
  echo "No Running Dev Spaces workspace found. Start a workspace from the devfile in the Dev Spaces tab (live mode). If this cluster has no Dev Spaces instance, follow the concept walkthrough — this check does not apply." >&2
  exit 1
fi
echo "OK: a Dev Spaces workspace is Running."
