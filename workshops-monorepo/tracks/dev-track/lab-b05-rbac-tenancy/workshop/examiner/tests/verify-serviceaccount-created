#!/bin/bash
# Verify the viewer-bot ServiceAccount was created.
if oc get serviceaccount viewer-bot >/dev/null 2>&1; then
  echo "OK: ServiceAccount 'viewer-bot' exists."
  exit 0
fi
echo "ServiceAccount 'viewer-bot' not found in $(oc project -q). Did 'oc apply -f serviceaccount-viewer.yaml' run?" >&2
exit 1
