#!/bin/bash
# Verify viewer-bot has NO access yet (checked before the Role/RoleBinding exist).
ns=$(oc project -q 2>/dev/null)
out=$(oc auth can-i get pods --as="system:serviceaccount:${ns}:viewer-bot" 2>/dev/null)
if [ "$out" != "no" ]; then
  echo "Expected 'no' for viewer-bot before any Role/RoleBinding is granted, got '$out'." >&2
  exit 1
fi
echo "OK: viewer-bot has no access yet (before state)."
exit 0
