#!/bin/bash
# Verify the learner can create Deployments in their own namespace.
out=$(oc auth can-i create deployments 2>/dev/null)
if [ "$out" != "yes" ]; then
  echo "Expected 'yes' from 'oc auth can-i create deployments', got '$out'." >&2
  exit 1
fi
echo "OK: 'oc auth can-i create deployments' returned yes."
exit 0
