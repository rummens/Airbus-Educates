#!/bin/bash
# verify-remediated-running <pod> — after remediation the pod is admitted and Running.
name="${1:?pod name required}"
phase=$(oc get pod "$name" -o jsonpath='{.status.phase}' 2>/dev/null)
if [ "$phase" != "Running" ]; then
  echo "Pod '$name' is '${phase:-not found}', expected Running. If it is still absent, the apply was rejected again — re-check the securityContext edits (runAsNonRoot, allowPrivilegeEscalation:false, capabilities.drop [ALL], seccompProfile RuntimeDefault; no privileged, no runAsUser:0)." >&2
  exit 1
fi
echo "OK: pod '$name' is Running — the remediated spec was admitted."
