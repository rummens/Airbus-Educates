#!/bin/bash
# verify-secret-decodable <secret> <key> <expected-token>
# base64-decoding the stored value returns the original token — proving a Secret is
# ENCODED, not encrypted. The "aha": encoding is trivially reversible; RBAC + etcd
# encryption at rest are what actually protect it.
name="${1:?secret name required}"
key="${2:?data key required}"
expected="${3:?expected decoded token required}"
decoded=$(oc get secret "$name" -o jsonpath="{.data.$key}" 2>/dev/null | base64 -d 2>/dev/null)
if [ "$decoded" != "$expected" ]; then
  echo "Decoding secret '$name' key '$key' gave '${decoded:-<empty>}', expected '$expected'. Did you apply secret.yaml?" >&2
  exit 1
fi
echo "OK: base64-decoding '$name/$key' returns the token — base64 is encoding, not encryption; RBAC + etcd encryption protect the Secret."
