#!/bin/bash
# verify-secret-exists <secret> <key> — the secret exists and carries the given data key.
name="${1:?secret name required}"
key="${2:?data key required}"
if ! oc get secret "$name" >/dev/null 2>&1; then
  echo "Secret '$name' not found. Apply secret.yaml first ('oc apply -f secret.yaml')." >&2
  exit 1
fi
val=$(oc get secret "$name" -o jsonpath="{.data.$key}" 2>/dev/null)
if [ -z "$val" ]; then
  echo "Secret '$name' has no data key '$key'. Check 'oc describe secret $name'." >&2
  exit 1
fi
echo "OK: secret '$name' exists with key '$key'."
