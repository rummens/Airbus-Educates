#!/bin/bash
# verify-leak-visible <deployment> <literal>
# The plaintext literal IS visible in the env dump — this proves the leak (bad pattern).
name="${1:?deployment name required}"
literal="${2:?expected plaintext literal required}"
env=$(oc set env "deploy/$name" --list 2>/dev/null)
if [ -z "$env" ]; then
  echo "Could not read env for deploy/$name. Did you apply deploy-leaky.yaml?" >&2
  exit 1
fi
if ! echo "$env" | grep -q "$literal"; then
  echo "Did not find the plaintext literal in 'oc set env deploy/$name --list'. Expected it to be exposed there. Did you apply deploy-leaky.yaml?" >&2
  exit 1
fi
echo "OK: the plaintext literal is visible in deploy/$name's env dump — that is the leak."
