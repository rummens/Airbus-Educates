#!/bin/bash
# verify-deploy-ready <deployment> — deployment has >=1 available replica in the session namespace.
name="${1:?deployment required}"
avail=$(oc get deployment "$name" -o jsonpath='{.status.availableReplicas}' 2>/dev/null)
if [ -z "$avail" ] || [ "$avail" -lt 1 ] 2>/dev/null; then
  echo "Deployment '$name' has no available replicas yet (got '${avail:-none}'). Check 'oc describe deployment $name'." >&2
  exit 1
fi
echo "OK: deployment '$name' has $avail available replica(s)."
