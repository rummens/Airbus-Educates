#!/bin/bash
# verify-egress-blocked <deployment> — an external HTTPS call from inside the pod must
# fail/time out, proving the platform's air-gapped egress restriction.
name="${1:?deployment required}"
pod=$(oc get pod -l app="$name" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)
if [ -z "$pod" ]; then
  echo "No pod found for app '$name'. Is the workload running?" >&2
  exit 1
fi
# Expect this to FAIL (non-zero) on an air-gapped platform.
if oc exec "$pod" -- curl -s -m 5 -o /dev/null https://example.com 2>/dev/null; then
  echo "External call to https://example.com SUCCEEDED from pod '$pod'. On an air-gapped platform egress should be blocked — this environment appears to have internet egress." >&2
  exit 1
fi
echo "OK: external egress from pod '$pod' was blocked/timed out (as expected on an air-gapped platform)."
