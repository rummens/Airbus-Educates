#!/bin/bash
# Verify the Secret exists. (Wiring it into the Deployment is a separate step,
# checked by verify-secret-injected.)
if oc get secret hello-dcs-secret >/dev/null 2>&1; then
  echo "OK: Secret 'hello-dcs-secret' exists."
  exit 0
fi
echo "Secret 'hello-dcs-secret' not found — did 'oc apply -f secret.yaml' run?" >&2
exit 1
