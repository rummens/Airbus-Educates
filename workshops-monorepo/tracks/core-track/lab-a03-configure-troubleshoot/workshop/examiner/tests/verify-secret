#!/bin/bash
# Verify the Secret exists and the Deployment references it.
if ! oc get secret hello-dcs-secret >/dev/null 2>&1; then
  echo "Secret 'hello-dcs-secret' not found — did 'oc apply -f secret.yaml' run?" >&2
  exit 1
fi
if oc get deploy hello-dcs -o yaml 2>/dev/null | grep -q 'hello-dcs-secret'; then
  echo "OK: Secret exists and is referenced by the Deployment."
  exit 0
fi
echo "Secret exists but the Deployment does not reference it." >&2
exit 1
