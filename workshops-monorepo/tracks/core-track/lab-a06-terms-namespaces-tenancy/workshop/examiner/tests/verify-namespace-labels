#!/bin/bash
# Verify the active namespace's labels are readable.
lbl=$(oc get namespace "$(oc project -q 2>/dev/null)" -o jsonpath='{.metadata.labels}' 2>/dev/null)
if [ -z "$lbl" ]; then
  echo "No labels found on namespace '$(oc project -q 2>/dev/null)'." >&2
  exit 1
fi
echo "OK: namespace labels: $lbl"
