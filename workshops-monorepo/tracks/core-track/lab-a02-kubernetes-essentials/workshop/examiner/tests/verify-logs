#!/bin/bash
# verify-logs <deployment>
# Passes when the deployment produces log output.
name="${1:?deployment name required}"
lines=$(oc logs "deployment/$name" --tail=20 2>/dev/null | wc -l | tr -d ' ')
if [ "${lines:-0}" -lt 1 ]; then
  echo "No logs from deployment/$name yet. Is a pod running? Check 'oc get pods'." >&2
  exit 1
fi
echo "OK: deployment/$name produced $lines log line(s)."
