#!/bin/bash
# Verify the Deployment owns a ReplicaSet (which owns the Pods).
# NB: we intentionally do NOT gate on `oc get all` — in a restricted namespace it
# exits non-zero when the SA can't list some built-in type, even though the
# ReplicaSet lists fine. Check the RS directly.
rs=$(oc get rs -l app=hello-dcs -o name 2>/dev/null | head -1)
if [ -n "$rs" ]; then
  echo "OK: Deployment owns a ReplicaSet which owns the Pod(s): $rs"
  exit 0
fi
echo "No ReplicaSet found for app=hello-dcs — the Deployment should have created one." >&2
exit 1
