#!/bin/bash
# Verify the app serves the first customised greeting.
body=$(curl -s --max-time 5 localhost:8080 2>/dev/null)
if echo "$body" | grep -q "Hello from the DCS Academy"; then
  echo "OK: the app served your greeting."
  exit 0
fi
echo "Response did not contain the expected greeting. Got: ${body:-<empty>}" >&2
exit 1
