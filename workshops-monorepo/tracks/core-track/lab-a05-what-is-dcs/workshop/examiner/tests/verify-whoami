#!/bin/bash
# Verify the session is authenticated (oc whoami returns a user).
user=$(oc whoami 2>/dev/null)
if [ -z "$user" ]; then
  echo "Not authenticated: 'oc whoami' returned nothing. The session should already be logged in — try re-running the command." >&2
  exit 1
fi
echo "OK: authenticated as '$user'."
