#!/bin/bash
# Verify the Networking CLI view runs (Services/Routes) — parity call-out.
if oc get svc >/dev/null 2>&1 && oc get route >/dev/null 2>&1; then
  echo "OK: 'oc get svc,route' ran — the CLI twin of the console Networking view."; exit 0
fi
echo "'oc get svc,route' failed to run." >&2; exit 1
