#!/bin/bash
# Verify API_TOKEN is present in the container's environment (value not checked).
if oc exec deploy/hello-dcs -- printenv API_TOKEN >/dev/null 2>&1; then
  echo "OK: API_TOKEN is injected into the container (value not shown)."
  exit 0
fi
echo "API_TOKEN is not set in the container environment." >&2
exit 1
