#!/bin/bash
# Verify the Route exists and was admitted with a host.
host=$(oc get route hello-dcs -o jsonpath='{.spec.host}' 2>/dev/null)
if [ -z "$host" ]; then
  echo "Route 'hello-dcs' has no host yet — did 'oc apply -f route.yaml' run?" >&2
  exit 1
fi
admitted=$(oc get route hello-dcs -o jsonpath='{.status.ingress[0].conditions[?(@.type=="Admitted")].status}' 2>/dev/null)
if [ "$admitted" = "True" ] || [ -n "$host" ]; then
  echo "OK: Route admitted at host '$host'."
  exit 0
fi
echo "Route host set ('$host') but not yet Admitted." >&2
exit 1
