{
  "uid": "educates-health",
  "title": "Educates \u2014 Platform Health & Workshops",
  "tags": [
    "educates",
    "openshift"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS",
        "label": "Datasource",
        "query": "prometheus",
        "current": {
          "text": "OpenShift-Thanos (Educates)",
          "value": "bfrmdld143wn4d"
        },
        "hide": 0
      },
      {
        "type": "query",
        "name": "ns",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS}"
        },
        "query": {
          "query": "label_values(kube_deployment_spec_replicas, namespace)",
          "refId": "ns"
        },
        "regex": "/^(educates|.*-ui)$/",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Workshops",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Running workshops (Allocated)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(educates_workshopsession_info{phase=\"Allocated\"})",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(educates_workshopsession_info)",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Reserved / Available",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(educates_workshopsession_info{phase=\"Available\"})",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Training portals running",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(educates_trainingportal_info{phase=\"Running\"}) or vector(0)",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Running workshops by type (Allocated)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum by (workshop) (educates_workshopsession_info{phase=\"Allocated\"})",
          "legendFormat": "{{workshop}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sessions by phase over time",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 16,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (phase) (educates_workshopsession_info)",
          "legendFormat": "{{phase}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Sessions by workshop & phase",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum by (workshop, phase) (educates_workshopsession_info)",
          "legendFormat": "{{workshop}} / {{phase}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Backend component health",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Unavailable replicas",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_deployment_status_replicas_unavailable{namespace=~\"$ns\"})",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Ready pods",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 6,
        "y": 22,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_pod_status_ready{namespace=~\"$ns\",condition=\"true\"})",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Container restarts (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$ns\"}[1h]))",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Available replicas by deployment",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 18,
        "y": 22,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": {
          "calc": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum by (deployment) (kube_deployment_status_replicas_available{namespace=~\"$ns\"})",
          "legendFormat": "{{deployment}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage by pod (cores)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$ns\",container!=\"\",container!=\"POD\"}[5m]))",
          "legendFormat": "{{pod}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory working set by pod",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$ns\",container!=\"\",container!=\"POD\"})",
          "legendFormat": "{{pod}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container restarts over time (15m increase)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"$ns\"}[15m]))",
          "legendFormat": "{{pod}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS}"
          }
        }
      ]
    }
  ]
}
