{
  "workshop": "lab-b02-config-and-secrets",
  "_note": "SCAFFOLD DRAFT \u2014 not CRC-validated. Needs authoring: the app deployment (deployment-configured.yaml) mounts BOTH the configmap and the secret, so the secret must be applied BEFORE the deploy or the rollout never becomes ready. Reorder: configmap+secret, then deploy, then the exec checks.",
  "steps": [
    {
      "run": "oc apply -f ~/exercises/configmap.yaml"
    },
    {
      "check": "verify-configmap",
      "args": [
        "hello-dcs-config"
      ]
    },
    {
      "run": "oc apply -f ~/exercises/deployment-configured.yaml"
    },
    {
      "run": "oc rollout status deployment/hello-dcs"
    },
    {
      "run": "oc exec deployment/hello-dcs -- printenv GREETING"
    },
    {
      "run": "oc exec deployment/hello-dcs -- cat /etc/hello-dcs/app.conf"
    },
    {
      "check": "verify-config-delivered",
      "args": []
    },
    {
      "run": "oc apply -f ~/exercises/secret.yaml"
    },
    {
      "check": "verify-secret-referenced",
      "args": [
        "hello-dcs-secret"
      ]
    },
    {
      "run": "oc exec deployment/hello-dcs -- sh -c 'printenv | cut -d= -f1 | grep API_TOKEN'"
    },
    {
      "run": "oc apply -f ~/exercises/configmap.yaml"
    },
    {
      "run": "oc rollout restart deployment/hello-dcs"
    },
    {
      "run": "oc rollout status deployment/hello-dcs"
    },
    {
      "run": "oc exec deployment/hello-dcs -- printenv GREETING"
    },
    {
      "check": "verify-config-delivered",
      "args": [
        "Hello from DCS PROD"
      ]
    },
    {
      "check": "verify-config-delivered",
      "args": []
    }
  ]
}
