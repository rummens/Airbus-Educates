# DCS Academy feedback collector — stdlib-only Python service (SQLite on a PV).
# Red Hat UBI9 Python base: hardened, non-root, arbitrary-UID friendly (runs
# under OpenShift's restricted SCC like the hello-dcs sample app).
FROM registry.access.redhat.com/ubi9/python-312:latest

WORKDIR /opt/app
COPY app.py /opt/app/app.py

# Data dir for the SQLite file (mounted PV in-cluster). Group-writable so an
# arbitrary UID in group 0 can write when no fsGroup is applied.
USER 0
# tzdata so zoneinfo can render Europe/Berlin timestamps in the admin view.
RUN pip install --no-cache-dir tzdata \
 && mkdir -p /data && chgrp -R 0 /data && chmod -R g=u /data /opt/app
USER 1001

ENV FEEDBACK_DB=/data/feedback.db \
    PORT=8080 \
    PYTHONUNBUFFERED=1
EXPOSE 8080
CMD ["python3", "/opt/app/app.py"]
