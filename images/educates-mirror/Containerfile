# Educates installer-bundle mirror tool — imgpkg baked into a small image so the
# bundle relocation can run as a Kubernetes Job (no fetching tools at runtime, so
# it works in an air gap once THIS image is mirrored).
#
# imgpkg needs NO container engine and NO virtualization — it speaks the OCI
# registry API directly over HTTPS and honors HTTP(S)_PROXY for egress to ghcr.
# The only real requirement is memory + scratch disk, which the Job sets.
FROM registry.access.redhat.com/ubi9/ubi-minimal

ARG TARGETARCH=amd64
ARG IMGPKG_VERSION=v0.44.0

LABEL org.opencontainers.image.source="https://github.com/rummens/Airbus-Educates" \
      org.opencontainers.image.description="imgpkg-in-a-box: relocate the Educates installer bundle into a private registry"

RUN set -eux; \
    microdnf -y install ca-certificates; microdnf clean all; \
    case "${TARGETARCH}" in \
      arm64) A=arm64 ;; \
      amd64) A=amd64 ;; \
      *) echo "unsupported arch: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/carvel-dev/imgpkg/releases/download/${IMGPKG_VERSION}/imgpkg-linux-${A}" \
      -o /usr/local/bin/imgpkg; \
    chmod +x /usr/local/bin/imgpkg
# NB: don't run `imgpkg version` here — under cross-arch QEMU emulation the foreign
# binary fails to exec and breaks multi-arch builds. It runs fine natively.

COPY mirror.sh /usr/local/bin/mirror.sh
RUN chmod +x /usr/local/bin/mirror.sh

USER 1001
ENTRYPOINT ["/usr/local/bin/mirror.sh"]
