{
  "uid": "dcs-academy-feedback",
  "title": "DCS Academy — Workshop Feedback",
  "tags": ["educates", "feedback"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "OpenShift-Thanos (Educates)", "value": "bfrmdld143wn4d" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total responses",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [ { "refId": "A", "expr": "sum(feedback_responses_total{workshop!=\"\"})" } ],
      "fieldConfig": { "defaults": { "decimals": 0 } }
    },
    {
      "id": 2, "type": "stat", "title": "Overall avg rating (weighted)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [ { "refId": "A", "expr": "sum(feedback_rating_avg{workshop!=\"\"} * feedback_responses_total{workshop!=\"\"}) / sum(feedback_responses_total{workshop!=\"\"})" } ],
      "fieldConfig": { "defaults": { "decimals": 2, "min": 1, "max": 5,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "orange", "value": 3 }, { "color": "green", "value": 4 } ] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Total comments",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [ { "refId": "A", "expr": "sum(feedback_comments_total{workshop!=\"\"})" } ],
      "fieldConfig": { "defaults": { "decimals": 0 } }
    },
    {
      "id": 4, "type": "bargauge", "title": "Average rating by course",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [ { "refId": "A", "expr": "feedback_rating_avg{workshop!=\"\"}", "legendFormat": "{{workshop}}", "instant": true } ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "decimals": 2, "min": 0, "max": 5,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "orange", "value": 3 }, { "color": "green", "value": 4 } ] } } }
    },
    {
      "id": 5, "type": "table", "title": "Responses & clarity by course",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [
        { "refId": "A", "expr": "feedback_responses_total{workshop!=\"\"}", "legendFormat": "{{workshop}}", "instant": true, "format": "table" },
        { "refId": "B", "expr": "feedback_rating_avg{workshop!=\"\"}", "legendFormat": "{{workshop}}", "instant": true, "format": "table" },
        { "refId": "C", "expr": "feedback_clarity_avg{workshop!=\"\"}", "legendFormat": "{{workshop}}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge" },
        { "id": "organize", "options": { "renameByName": {
          "workshop": "Workshop", "Value #A": "Responses", "Value #B": "Avg rating", "Value #C": "Avg clarity" },
          "excludeByName": { "Time": true, "__name__": true, "container": true, "endpoint": true,
            "instance": true, "job": true, "namespace": true, "pod": true, "service": true } } }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Responses over time (per course)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "targets": [ { "refId": "A", "expr": "feedback_responses_total{workshop!=\"\"}", "legendFormat": "{{workshop}}" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
