{
  "workshop": "lab-a02-kubernetes-essentials",
  "steps": [
    {"check": "verify-deployment-absent", "args": ["hello-dcs"]},
    {"run": "envsubst < deployment.yaml | oc apply -f -"},
    {"run": "oc rollout status deployment/hello-dcs --timeout=120s"},
    {"check": "verify-replicas", "args": ["hello-dcs", "1"]},
    {"check": "verify-pods-running", "args": ["hello-dcs", "1"]},
    {"check": "verify-deployment-exists", "args": ["hello-dcs"]},
    {"check": "verify-labels", "args": ["hello-dcs"]},
    {"run": "oc apply -f service.yaml"},
    {"check": "verify-service", "args": ["hello-dcs"]},
    {"check": "verify-svc-reachable", "args": ["hello-dcs", "8080"]},
    {"run": "oc scale deployment/hello-dcs --replicas=3"},
    {"check": "verify-replicas", "args": ["hello-dcs", "3"]},
    {"check": "verify-pods-running", "args": ["hello-dcs", "3"]},
    {"check": "verify-logs", "args": ["hello-dcs"]},
    {"check": "verify-exec", "args": ["hello-dcs"]}
  ]
}
